# EVM RPC endpoint (Alchemy, Infura, QuickNode, etc.)
# Archive node required for historical block snapshots
EVM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Solana RPC endpoint
